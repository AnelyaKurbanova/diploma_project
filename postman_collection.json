        {
          "name": "POST /auth/register/verify",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"code\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register/verify",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register",
                "verify"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  try {",
                  "    var data = pm.response.json();",
                  "    if (data.access_token) {",
                  "      pm.collectionVariables.set('accessToken', data.access_token);",
                  "    }",
                  "  } catch (e) {}",
                  "  var refresh = pm.cookies.get('refresh_token');",
                  "  if (refresh) {",
                  "    pm.collectionVariables.set('refreshToken', refresh);",
                  "  }",
                  "  var csrf = pm.cookies.get('csrf_token');",
                  "  if (csrf) {",
                  "    pm.collectionVariables.set('csrfToken', csrf);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
