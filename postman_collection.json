              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            },
            "description": "Uses refresh_token cookie and X-CSRF-Token header. Tokens are stored automatically in collection variables."
